# check that haneul move new correctly updates existing .gitignore
mkdir example
echo "existing_ignore" > example/.gitignore
haneul move new example
cat example/.gitignore

----- results -----
success: true
exit_code: 0
----- stdout -----
existing_ignore
build/*
traces/*
.trace
.coverage*

