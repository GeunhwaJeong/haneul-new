chain_id=$(haneul client --client.config $CONFIG chain-identifier)
echo "[environments]" >> test_pkg/Move.toml
echo "localnet = \"$chain_id\"" >> test_pkg/Move.toml

haneul client --client.config $CONFIG ptb \
 --move-call haneul::tx_context::sender \
 --assign sender \
 --publish "test_pkg" \
 --assign upgrade_cap \
 --transfer-objects "[upgrade_cap]" sender \
 > output.log 2>&1 || cat output.log

----- results -----
success: true
exit_code: 0
