# Default values for some env variables. Use .env to add/change variables for the
# current environment.

API_ENV=devNet
API_ENDPOINT_LOCAL=http://127.0.0.1:5001/
API_ENDPOINT_LOCAL_FULLNODE=http://127.0.0.1:9000/
API_ENDPOINT_DEV_NET=https://gateway.devnet.haneul.io/
API_ENDPOINT_DEV_NET_FULLNODE=https://fullnode.devnet.haneul.io/
API_ENDPOINT_STAGING=https://gateway.staging.haneul.io/
API_ENDPOINT_STAGING_FULLNODE=https://fullnode.staging.haneul.io/
EXPLORER_URL_LOCAL=http://localhost:8080/
EXPLORER_URL_DEV_NET=https://explorer.devnet.haneul.io/
EXPLORER_URL_STAGING=https://explorer.staging.haneul.io/
SHOW_STAGING=false
STAKING_ENABLED=false
