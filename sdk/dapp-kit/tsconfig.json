{
	"extends": "../build-scripts/tsconfig.shared.json",
	"include": ["src"],
	"compilerOptions": {
		"module": "CommonJS",
		"outDir": "dist/cjs",
		"isolatedModules": true,
		"jsx": "react-jsx",
		"baseUrl": "..",
		"rootDir": "src",
		"paths": {
			"@haneullabs/haneul.js/transactions": ["../typescript/src/builder/export.ts"],
			"@haneullabs/haneul.js/*": ["../typescript/src/*"],
			"@haneullabs/haneul.js": ["../typescript/src/"],
			"@haneullabs/wallet-standard": ["../wallet-standard/src"]
		}
	},
	"references": [{ "path": "../typescript" }, { "path": "../wallet-standard" }]
}
