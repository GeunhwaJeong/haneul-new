{
  "name": "@haneullabs/bcs",
  "version": "0.2.0",
  "description": "BCS - Canonical Binary Serialization implementation for JavaScript",
  "license": "Apache-2.0",
  "author": "Haneul Labs <build@haneul-labs.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm build:types && tsup ./src/index.ts --format esm,cjs --sourcemap",
    "build:types": "tsc --build",
    "prepublishOnly": "pnpm build",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeunhwaJeong/haneul.git"
  },
  "keywords": [
    "bcs",
    "libra",
    "diem",
    "move",
    "serialization",
    "serde"
  ],
  "bugs": {
    "url": "https://github.com/GeunhwaJeong/haneul/issues"
  },
  "homepage": "https://github.com/GeunhwaJeong/haneul#readme",
  "dependencies": {
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "tsup": "^6.2.2",
    "typescript": "^4.8.2",
    "vitest": "^0.22.1"
  }
}
