{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "~/*": ["./src/*"],
            "@haneullabs/haneul.js": ["../../sdk/typescript/src/"],
            "@haneullabs/bcs": ["../../sdk/bcs/src/"],
            "@haneullabs/wallet-adapter-base": [
                "../../sdk/wallet-adapter/packages/adapters/base-adapter/src/"
            ],
            "@haneullabs/wallet-standard": [
                "../../sdk/wallet-adapter/packages/wallet-standard/src/"
            ],
            "@haneullabs/wallet-adapter-all-wallets": [
                "../../sdk/wallet-adapter/packages/adapters/all-wallets/src/"
            ],
            "@haneullabs/wallet-adapter-unsafe-burner": [
                "../../sdk/wallet-adapter/packages/adapters/unsafe-burner/src/"
            ],
            "@haneullabs/wallet-adapter-wallet-standard": [
                "../../sdk/wallet-adapter/packages/adapters/wallet-standard-adapter/src/"
            ],
            "@haneullabs/wallet-adapter-react": [
                "../../sdk/wallet-adapter/packages/react-providers/src/"
            ],
            "@haneullabs/wallet-kit": [
                "../../sdk/wallet-adapter/packages/wallet-kit/src/"
            ]
        }
    },
    "include": ["src"]
}
