{
  "name": "@haneullabs/wallet-adapter-base",
  "version": "0.0.0",
  "description": "Base wallet adapter for Haneul",
  "license": "Apache-2.0",
  "author": "Haneul Labs <build@haneul-labs.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "pnpm build:types && tsup ./src/index.ts --format esm,cjs --sourcemap",
    "build:types": "tsc --build",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@haneullabs/haneul.js": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^6.2.2",
    "typescript": "^4.8.2"
  }
}
